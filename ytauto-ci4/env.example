# ============================================================
# YT.AUTO — Environment Configuration
# Renomeie este arquivo para .env e configure seus valores
# ============================================================

CI_ENVIRONMENT = development

# App
app.baseURL = 'http://localhost/ytauto/public/'

# Database
database.default.hostname = localhost
database.default.database = ytauto
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port = 3306

# Session
app.sessionSavePath = /path/to/writable/session
